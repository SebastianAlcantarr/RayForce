{"file":"TheNavbar.vue.mjs","mappings":";;;;;;;;AAyDA,UAAM,QAAQ,SAAQ;AAEtB,UAAM,WAAW;AAAA,MACf,EAAE,OAAO,UAAU,MAAM,IAAG;AAAA,MAC5B,EAAE,OAAO,UAAU,MAAM,UAAS;AAAA,MAClC,EAAE,OAAO,aAAa,MAAM,aAAY;AAAA,MACxC,EAAE,OAAO,oBAAoB,MAAM,WAAU;AAAA,MAC7C,EAAE,OAAO,YAAY,MAAM,YAAW;AAAA,MACtC,EAAE,OAAO,YAAY,MAAM,YAAW;AAAA,IACxC;AAEA,UAAM,cAAc,IAAI,EAAE;AACX,cAAS;AASxB,UAAM,WAAW,CAAC,SAAS;AACzB,UAAI,KAAK,SAAS,KAAK;AACrB,eAAO,MAAM,SAAS;AAAA,MACxB;AAEA,aAAO,MAAM,KAAK,WAAW,KAAK,IAAI;AAAA,IACxC;;;AAnFO,YAAA,OAAAA,eAAAC,WAAA,EAAA,OAAM,sGAAkG,MAAA,CAAA,CAAA,8FAAA;;QAG/F,IAAG;AAAA,QAAI,OAAM;AAAA;yBAAvB,CAEW,GAAAC,QAAAC,UAAA,aAAA;;;;;8BAFiF,YAE5F;AAAA;;;;;;AAKmBC,oBAAA,WAAR,SAAI;;UACV,KAAK,KAAK;AAAA,UACV,IAAI,KAAK;AAAA,UACT,OAAO,SAAS,IAAI;;2BAJvB,CASW,GAAAF,QAAAC,UAAA,aAAA;;AADN,cAAAD,OAAA,GAAAG,eAAA,KAAK,KAAK,CAAA,EAAA;AAAA;;gBAAVC,gBAAAC,gBAAA,KAAK,KAAK,GAAA,CAAA;AAAA;;;;;;4SASFC,MAAA,WAAA,CAAW,CAAA,oMAAA;;QAQtB,IAAG;AAAA,QACH,OAAM;AAAA,QACN,cAAW;AAAA;yBAHb,CAMW,GAAAN,QAAAC,UAAA,aAAA;;;;;cADTM,YAA4D,QAAA,EAAtD,OAAM,4BAA2B,GAAC,eAAa;AAAA;;;;;;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","_push","_parent","_ssrRenderList","_ssrInterpolate","_createTextVNode","_toDisplayString","_unref","_createVNode"],"sources":["../../../../componentes_principal/TheNavbar.vue"],"sourcesContent":["<template>\r\n  <nav class=\"fixed top-0 w-full z-50 bg-[#f9f9fb]/70 backdrop-blur-xl font-manrope antialiased tracking-tight\">\r\n    <div class=\"flex justify-between items-center px-8 py-4 max-w-screen-2xl mx-auto relative\">\r\n      <!-- Logo -->\r\n      <NuxtLink to=\"/\" class=\"text-3xl md:text-5xl  tracking-tighter text-primary  font-rayforce\">\r\n        Rayforce\r\n      </NuxtLink>\r\n\r\n      <!-- Nav Links -->\r\n      <div class=\"hidden md:flex items-center space-x-8\">\r\n        <NuxtLink\r\n          v-for=\"link in navLinks\"\r\n          :key=\"link.label\"\r\n          :to=\"link.href\"\r\n          :class=\"isActive(link)\r\n            ? 'text-primary border-b-2 border-primary pb-1 font-bold'\r\n            : 'text-on-surface-variant font-medium hover:text-primary transition-colors'\"\r\n        >\r\n          {{ link.label }}\r\n        </NuxtLink>\r\n      </div>\r\n\r\n      <!-- Actions -->\r\n      <div class=\"flex items-center space-x-4\">\r\n        <div class=\"relative hidden lg:block group\">\r\n          <span class=\"material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline group-focus-within:text-primary transition-colors\">search</span>\r\n          <input\r\n            v-model=\"searchQuery\"\r\n            @keyup.enter=\"performSearch\"\r\n            class=\"pl-10 pr-4 py-2 bg-surface-container border-none focus:ring-2 focus:ring-primary rounded-lg text-sm w-56 outline-none transition-all\"\r\n            placeholder=\"Buscar productos...\"\r\n            type=\"text\"\r\n          />\r\n        </div>\r\n        <NuxtLink\r\n          to=\"/carrito\"\r\n          class=\"scale-95 active:opacity-80 transition-transform text-on-surface-variant hover:text-primary\"\r\n          aria-label=\"Carrito\"\r\n        >\r\n          <span class=\"material-symbols-outlined\">shopping_cart</span>\r\n        </NuxtLink>\r\n        <button\r\n          class=\"scale-95 active:opacity-80 transition-transform text-on-surface-variant hover:text-primary\"\r\n          aria-label=\"Cuenta\"\r\n          type=\"button\"\r\n        >\r\n          <span class=\"material-symbols-outlined\">account_circle</span>\r\n        </button>\r\n      </div>\r\n\r\n      <!-- Bottom border -->\r\n      <div class=\"bg-outline-variant h-[1px] w-full absolute bottom-0 opacity-15\" />\r\n    </div>\r\n  </nav>\r\n</template>\r\n\r\n<script setup>\r\nconst route = useRoute()\r\n\r\nconst navLinks = [\r\n  { label: 'Inicio', href: '/' },\r\n  { label: 'Tienda', href: '/tienda' },\r\n  { label: 'Servicios', href: '/servicios' },\r\n  { label: 'Cotizar Proyecto', href: '/cotizar' },\r\n  { label: 'Nosotros', href: '/nosotros' },\r\n  { label: 'Contacto', href: '/contacto' },\r\n]\r\n\r\nconst searchQuery = ref('')\r\nconst router = useRouter()\r\n\r\nfunction performSearch() {\r\n  if (searchQuery.value.trim()) {\r\n    router.push({ path: '/tienda', query: { q: searchQuery.value.trim() } })\r\n    searchQuery.value = ''\r\n  }\r\n}\r\n\r\nconst isActive = (link) => {\r\n  if (link.href === '/') {\r\n    return route.path === '/'\r\n  }\r\n\r\n  return route.path.startsWith(link.href)\r\n}\r\n</script>\r\n"],"version":3}