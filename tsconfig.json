{
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": ["node", "nuxt"],

    "moduleResolution": "bundler"
  },
  "include": [
    ".nuxt/nuxt.d.ts",
    ".nuxt/types/**/*.d.ts",
    ".nuxt/imports.d.ts",
    "./**/*.ts",
    "./**/*.tsx",
    "./**/*.vue",
    "pages/**/*.vue",
    "layouts/**/*.vue",
    "composables/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build"
  ]
}

